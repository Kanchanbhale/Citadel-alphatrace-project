# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Model config (gemini-2.0-flash is the recommended default)
GEMINI_MODEL=gemini-2.0-flash

# Output directory for artifacts
OUTPUTS_DIR=./outputs

# SEC EDGAR user agent (required by SEC — use your real email)
SEC_USER_AGENT=AlphaTrace Research your-email@domain.com
